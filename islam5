from tkinter import *
from tkinter import messagebox

def esepteu():
    try:
        san = float(entry.get())

        kvadrat = san ** 2
        kub = san ** 3

        natije.config(
            text=f"Квадраты: {kvadrat:g}\nКубы: {kub:g}"
        )

    except ValueError:
        natije.config(text="Қате: Сан енгізіңіз!")
        messagebox.showerror("Қате", "Сан енгізіңіз!")

# Терезе құру
window = Tk()
window.title("Санның квадратын және кубын есептеу")
window.geometry("350x220")
window.resizable(False, False)

# Жазу
Label(window, text="Санды енгізіңіз:", font=("Arial", 12)).pack(pady=10)

# Енгізу өрісі
entry = Entry(window, font=("Arial", 12), justify="center")
entry.pack(pady=5)

# Батырма
Button(
    window,
    text="Есептеу",
    font=("Arial", 12),
    command=esepteu
).pack(pady=10)

# Нәтиже
natije = Label(window, text="Нәтиже:", font=("Arial", 12))
natije.pack(pady=10)

# Бағдарламаны іске қосу
window.mainloop()
